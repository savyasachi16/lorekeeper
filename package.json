{
  "name": "lorekeeper",
  "version": "0.1.0",
  "description": "Build and maintain a persistent, LLM-curated wiki from your sources. A concrete implementation of Karpathy's LLM Wiki pattern.",
  "type": "module",
  "bin": {
    "lorekeeper": "./bin/lorekeeper",
    "lorekeeper-mcp": "./bin/lorekeeper-mcp"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "ora": "^8.1.0",
    "pdfjs-dist": "^4.7.76",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md"
  ]
}
